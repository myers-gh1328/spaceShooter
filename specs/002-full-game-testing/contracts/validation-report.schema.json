{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spaceshooter.local/schemas/validation-report.schema.json",
  "title": "NOVA DRIFT Validation Report",
  "type": "object",
  "required": [
    "runId",
    "timestamp",
    "buildRef",
    "environment",
    "results",
    "defects",
    "summary",
    "durationMin"
  ],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "buildRef": { "type": "string", "minLength": 1 },
    "environment": {
      "type": "object",
      "required": ["os", "browser"],
      "properties": {
        "os": { "type": "string" },
        "browser": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenarioId", "status", "observed", "durationSec", "attempts", "defectIds"],
        "properties": {
          "scenarioId": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail", "blocked"] },
          "observed": { "type": "string" },
          "durationSec": { "type": "number", "minimum": 0 },
          "attempts": { "type": "integer", "minimum": 1 },
          "notes": { "type": "string" },
          "defectIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "fail" } } },
            "then": {
              "properties": {
                "defectIds": { "minItems": 1 }
              }
            }
          },
          {
            "if": { "properties": { "status": { "const": "blocked" } } },
            "then": {
              "required": ["notes"],
              "properties": {
                "notes": { "minLength": 1 }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "scenarioId", "severity", "expected", "observed", "reproSteps", "state"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "scenarioId": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "expected": { "type": "string", "minLength": 1 },
          "observed": { "type": "string", "minLength": 1 },
          "reproSteps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "state": { "type": "string", "enum": ["open", "fixed", "verified"] }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["total", "pass", "fail", "blocked"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "durationMin": { "type": "number", "minimum": 0 },
    "comparison": {
      "type": "object",
      "required": ["baselineRunId", "currentRunId", "regressions", "fixes", "unchangedFailures", "newCoverage"],
      "properties": {
        "baselineRunId": { "type": "string" },
        "currentRunId": { "type": "string" },
        "regressions": { "type": "array", "items": { "type": "string" } },
        "fixes": { "type": "array", "items": { "type": "string" } },
        "unchangedFailures": { "type": "array", "items": { "type": "string" } },
        "newCoverage": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
